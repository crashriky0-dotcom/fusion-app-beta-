<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- TITOLO -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Scheda Preventivo"
            android:textSize="24sp"
            android:textStyle="bold"
            android:paddingBottom="12dp" />

        <!-- ===================== -->
        <!-- SMONTAGGIO -->
        <!-- ===================== -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Smontaggio"
            android:textStyle="bold"
            android:paddingTop="12dp"
            android:paddingBottom="8dp" />

        <CheckBox
            android:id="@+id/chkSmontaggio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Includi smontaggio" />

        <Spinner
            android:id="@+id/spnCatSmontaggio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:enabled="false" />

        <EditText
            android:id="@+id/edtSmontaggioEuro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:enabled="false"
            android:hint="€ Smontaggio"
            android:inputType="numberDecimal" />

        <TextView
            android:id="@+id/txtHintsSmontaggio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="A=90€  B=120€  C=150€  D=200€ (modificabile)"
            android:textSize="12sp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp" />

        <!-- ===================== -->
        <!-- RIMONTAGGIO -->
        <!-- ===================== -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Rimontaggio"
            android:textStyle="bold"
            android:paddingTop="12dp"
            android:paddingBottom="8dp" />

        <CheckBox
            android:id="@+id/chkRimontaggio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Includi rimontaggio" />

        <Spinner
            android:id="@+id/spnCatRimontaggio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:enabled="false" />

        <EditText
            android:id="@+id/edtRimontaggioEuro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:enabled="false"
            android:hint="€ Rimontaggio"
            android:inputType="numberDecimal" />

        <TextView
            android:id="@+id/txtHintsRimontaggio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="A=90€  B=120€  C=150€  D=200€ (modificabile)"
            android:textSize="12sp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp" />

        <!-- ===================== -->
        <!-- PANNELLI AUTO -->
        <!-- ===================== -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pannelli auto"
            android:textStyle="bold"
            android:textSize="18sp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:id="@+id/panelContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- ===================== -->
        <!-- PREZZO -->
        <!-- ===================== -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PREZZO"
            android:textStyle="bold"
            android:paddingTop="16dp" />

        <TextView
            android:id="@+id/txtTotaleConsigliato"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Totale consigliato: 0 €"
            android:textSize="18sp"
            android:paddingTop="6dp" />

        <EditText
            android:id="@+id/edtPrezzoReale"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Prezzo reale €"
            android:inputType="numberDecimal" />

        <TextView
            android:id="@+id/txtScontoEffettivo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sconto effettivo: 0%"
            android:paddingTop="6dp" />

    </LinearLayout>
</ScrollView>
